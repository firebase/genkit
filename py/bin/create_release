# Create a git tag and GitHub release for a Python SDK version.
#
# Usage:
#   ./bin/create_release <VERSION> [NOTES_FILE]
#
# Examples:
#   ./bin/create_release 0.7.0 notes.md   # Use curated release notes
#   ./bin/create_release 0.7.0            # Opens $EDITOR to write notes
#
# The version must match the version in packages/genkit/pyproject.toml.
# Triggers the publish-python workflow when the tag is pushed.

set -euo pipefail

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "Usage: $0 <VERSION> [NOTES_FILE]"
  echo "Examples:"
  echo "  $0 0.7.0 notes.md   # Use curated release notes"
  echo "  $0 0.7.0            # Opens \$EDITOR to write notes"
  exit 1
fi

VERSION="$1"
NOTES_FILE="${2:-}"
TAG="py/v${VERSION}"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PY_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"
REPO_ROOT="$(cd "${PY_DIR}/.." && pwd)"
cd "$REPO_ROOT"

# Verify version in pyproject.toml matches.
ACTUAL=$(grep '^version' py/packages/genkit/pyproject.toml | head -1 | sed 's/.*"\(.*\)".*/\1/')
if [ "$ACTUAL" != "$VERSION" ]; then
  echo "Error: pyproject.toml has version $ACTUAL, expected $VERSION"
  exit 1
fi

# Verify clean state on main.
[ "$(git branch --show-current)" = "main" ] || { echo "Error: not on main branch"; exit 1; }
git diff-index --quiet HEAD -- || { echo "Error: uncommitted changes"; exit 1; }

# Verify tag doesn't already exist.
if git rev-parse "$TAG" >/dev/null 2>&1; then
  echo "Error: tag $TAG already exists"
  exit 1
fi

git pull origin main

git tag -a "$TAG" -m "Genkit Python SDK v${VERSION}"
git push origin "$TAG"

if [ -n "$NOTES_FILE" ]; then
  [ -f "$NOTES_FILE" ] || { echo "Error: notes file not found: $NOTES_FILE"; exit 1; }
  gh release create "$TAG" --title "Genkit Python SDK v${VERSION}" --notes-file "$NOTES_FILE"
else
  gh release create "$TAG" --title "Genkit Python SDK v${VERSION}"
fi

echo ""
echo "Done. Tag $TAG pushed and release created."
echo "https://github.com/firebase/genkit/releases/tag/${TAG}"
echo ""
echo "The publish-python workflow should trigger automatically."
echo "Monitor at: https://github.com/firebase/genkit/actions"
